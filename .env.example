# ──────────────────────────────────────────────────────────────────────────────
# .env.example — Plantilla de variables de entorno para el MLflow Production Stack
#
# Instrucciones:
#   1. Copia este fichero: cp .env.example .env
#   2. Rellena todos los valores marcados con CHANGE_ME
#   3. Genera MLFLOW_SECRET_KEY con: python3 -c "import secrets; print(secrets.token_hex(32))"
#   4. Nunca subas el fichero .env al repositorio (ya está en .gitignore)
# ──────────────────────────────────────────────────────────────────────────────

# ── Dominio y TLS ─────────────────────────────────────────────────────────────
# Dominio público apuntando al servidor donde se desplegará el stack
DOMAIN=mlflow.pathologyprediction.es
# Email para notificaciones de Let's Encrypt (caducidad de certificados, etc.)
CERTBOT_EMAIL=jiramirez@fidesol.org

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Base de datos backend para metadatos de MLflow (experimentos, runs, métricas)
POSTGRES_DB=mlflow
POSTGRES_USER=mlflow
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── MLflow ────────────────────────────────────────────────────────────────────
# Imagen Docker de MLflow (prebuilt en GitHub Container Registry).
# Cambia el tag para apuntar a una versión específica o :latest para la última.
MLFLOW_IMAGE=ghcr.io/josemlp91/mlflow-production-stack/mlflow:latest
# Usuario administrador inicial — puede gestionar el resto de usuarios
MLFLOW_ADMIN_USERNAME=admin
MLFLOW_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
# Clave secreta de Flask para firmar las cookies de sesión de la UI
# Generar con: python3 -c "import secrets; print(secrets.token_hex(32))"
MLFLOW_SECRET_KEY=CHANGE_ME_RANDOM_HEX_32_CHARS

# ── MinIO (almacenamiento de artefactos S3-compatible) ────────────────────────
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=CHANGE_ME_STRONG_PASSWORD
# Nombre del bucket donde MLflow almacenará los artefactos (modelos, plots, etc.)
MINIO_BUCKET=mlflow-artifacts
